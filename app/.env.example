# API-endpoint бэкенда (Supabase Edge Functions или своя API).
# В Vercel задаётся через Settings → Environment Variables.
VITE_API_BASE_URL=https://your-project.supabase.co/functions/v1

# (опционально) URL Supabase + anon-key, если фронт ходит туда напрямую
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=...
