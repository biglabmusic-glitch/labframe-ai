# Telegram-токен бота — получить у @BotFather → /newbot
BOT_TOKEN=1234567890:AAAA-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL мини-аппа — куда открывать кнопкой
MINI_APP_URL=https://labframe-ai.vercel.app

# Webhook URL бота (тот же домен, по которому Railway пробрасывает /webhook)
WEBHOOK_URL=https://labframe-ai-bot.up.railway.app/webhook

# Опционально: секрет для верификации Telegram (любая случайная строка)
WEBHOOK_SECRET=change-me-to-random-string

# Порт (Railway пробрасывает автоматически через PORT)
PORT=3000
